# Google Cloud Settings
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=your-gcp-location

# Google Cloud BigQuery configuration
BIGQUERY_PROJECT=your-bigquery-project-id
# BIGQUERY_LOCATION takes precedence over GOOGLE_CLOUD_LOCATION if both are set
BIGQUERY_LOCATION=us-central1
BIGQUERY_DATASET=your-bigquery-dataset
BIGQUERY_GRAPH_NAME=your-bigquery-graph-name

# Use Vertex AI with Application Default Credentials (no API key required)
GOOGLE_GENAI_USE_VERTEXAI=true

# LLM configuration
LLM_MODEL_NAME=gemini-2.5-flash
EMBEDDING_MODEL_NAME=gemini-embedding-001
